# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=money_tracker
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# Email (Brevo: SMTP & API → usuario = email que muestra, contraseña = SMTP Key, puerto 587)
SMTP_HOST=tu-smtp-host
SMTP_PORT=port
SMTP_USER=tu-email@ejemplo.com
SMTP_PASS=tu_smtp_key_de_brevo
EMAIL_FROM=Money Tracker <no-reply@tu-dominio.com>

# Almacenamiento: MinIO (local/Docker) o AWS S3
# --- MinIO (desarrollo) ---
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=minio
# MINIO_SECRET_KEY=minio123
# MINIO_BUCKET=money-tracker

# --- AWS S3 (producción, bucket money-tracker-uploads) ---
S3_ENDPOINT=s3.amazonaws.com
S3_PORT=443
S3_USE_SSL=true
AWS_ACCESS_KEY_ID=tu-access-key-id
AWS_SECRET_ACCESS_KEY=tu-secret-access-key
AWS_REGION=eu-west-1
S3_BUCKET=money-tracker-uploads
